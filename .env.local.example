# Database (Neon)
DATABASE_URL=postgres://user:pass@ep-xxxx.neon.tech/clipmind?sslmode=require

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
